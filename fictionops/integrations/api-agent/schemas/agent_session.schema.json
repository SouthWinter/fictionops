{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://southwinter.github.io/fictionops/schemas/v1/agent_session.schema.json",
  "title": "AgentSession",
  "type": "object",
  "required": ["api_version", "session_id", "status", "goal", "staged_outputs"],
  "properties": {
    "api_version": {
      "type": "string",
      "const": "1.0"
    },
    "session_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["planned", "running", "waiting_for_review", "completed", "failed"]
    },
    "goal": {
      "$ref": "./agent_goal.schema.json"
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "status"],
        "properties": {
          "name": { "type": "string" },
          "status": { "type": "string" },
          "summary": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "staged_outputs": {
      "type": "array",
      "items": {
        "$ref": "./staged_output.schema.json"
      }
    },
    "stop_reason": {
      "type": "string"
    },
    "metrics": {
      "type": "object",
      "additionalProperties": true
    },
    "runtime_report": {
      "type": "object",
      "description": "JSON-serializable report returned by the canonical FictionOps Python API.",
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
