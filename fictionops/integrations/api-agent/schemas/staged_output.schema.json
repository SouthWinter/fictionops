{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://southwinter.github.io/fictionops/schemas/v1/staged_output.schema.json",
  "title": "StagedOutput",
  "type": "object",
  "required": ["run_dir", "output_file", "role", "task", "state", "review_required"],
  "properties": {
    "run_dir": {
      "type": "string"
    },
    "output_file": {
      "type": "string"
    },
    "role": {
      "type": "string"
    },
    "task": {
      "type": "string"
    },
    "book": {
      "type": "string"
    },
    "chapter": {
      "type": "string"
    },
    "state": {
      "type": "string",
      "enum": ["draft", "revision", "audit", "accepted", "rejected"]
    },
    "review_required": {
      "type": "boolean"
    },
    "source": {
      "type": "object",
      "properties": {
        "provider": { "type": "string" },
        "model": { "type": "string" },
        "runner": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
