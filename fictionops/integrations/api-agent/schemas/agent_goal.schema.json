{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://southwinter.github.io/fictionops/schemas/v1/agent_goal.schema.json",
  "title": "AgentGoal",
  "type": "object",
  "required": ["project_path", "goal", "role", "acceptance_mode"],
  "properties": {
    "project_path": {
      "type": "string",
      "description": "Path or project identifier for the FictionOps project."
    },
    "goal": {
      "type": "string",
      "description": "Human-readable task goal."
    },
    "book": {
      "type": "string",
      "description": "Book identifier such as book_01."
    },
    "chapter": {
      "type": "string",
      "description": "Chapter identifier such as 001."
    },
    "runtime_mode": {
      "type": "string",
      "enum": ["closed_loop", "bundle"],
      "default": "closed_loop"
    },
    "chapter_file": {
      "type": "string",
      "description": "Chapter Markdown path used by the canonical closed-loop runtime."
    },
    "engine_file": {
      "type": "string",
      "description": "Required chapter engine path for closed-loop writing."
    },
    "outline_file": { "type": "string" },
    "review_file": { "type": "string" },
    "role": {
      "type": "string",
      "description": "Agent role such as draft-writer, revision-editor, or continuity-auditor."
    },
    "provider": {
      "type": "string",
      "description": "Model provider preset or deployment name."
    },
    "model": {
      "type": "string",
      "description": "Model name passed to the provider."
    },
    "max_steps": {
      "type": "integer",
      "minimum": 1,
      "default": 3
    },
    "out_dir": {
      "type": "string",
      "description": "Optional FictionOps agent-run output directory."
    },
    "runner_command": {
      "type": "array",
      "description": "Optional external runner command. When omitted, the server only prepares the agent-run bundle.",
      "items": {
        "type": "string"
      }
    },
    "timeout_seconds": {
      "type": "integer",
      "minimum": 1,
      "default": 300
    },
    "max_model_calls": { "type": "integer", "minimum": 1 },
    "max_runtime_seconds": { "type": "integer", "minimum": 1 },
    "max_total_tokens": { "type": "integer", "minimum": 1 },
    "max_cost": { "type": "number", "exclusiveMinimum": 0 },
    "cost_currency": { "type": "string", "default": "USD" },
    "review_scope": { "type": "string", "enum": ["style", "comprehensive"] },
    "semantic_verify": { "type": "boolean", "default": true },
    "force": {
      "type": "boolean",
      "default": false
    },
    "force_output": {
      "type": "boolean",
      "default": false
    },
    "output_name": {
      "type": "string",
      "default": "output.md"
    },
    "acceptance_mode": {
      "type": "string",
      "enum": ["human_governed"],
      "description": "FictionOps v1 adapter drafts require human-governed acceptance."
    }
  },
  "additionalProperties": true
}
